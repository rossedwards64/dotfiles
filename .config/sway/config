set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty
set $menu $HOME/.config/polybar/forest/scripts/launcher.sh

font pango:Iosevka 10

### Monitor settings
output HDMI-A-1 resolution 1920x1080@75Hz transform 270 pos 0 0 bg /home/ross/Pictures/wallpapers/Evangelion/landscape.jpg fill
output DP-1 resolution 1920x1080@144Hz transform 0 pos 1080 670 bg /home/ross/Pictures/wallpapers/Gurren\ Lagann/simon.jpg fill

### Idle configuration
exec swayidle -w \
         timeout 300 'swaylock -f -S --effect-blur 10x5' \
         timeout 600 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
         before-sleep 'swaylock -f -S --effect-blur 10x5'

### Startup apps
exec alacritty
exec emacsclient -c -a=""
exec discord
exec steam
exec firefox

### Key bindings
    bindsym $mod+Return exec $term
    bindsym $mod+Shift+g exec emacsclient -c -a=""
    bindsym $mod+Shift+q kill
    bindsym $mod+d exec $menu
    floating_modifier $mod normal
    bindsym $mod+Shift+c reload
    bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
    bindsym XF86AudioRaiseVolume exec amixer -M set Master 5%+ && $refresh_i3status
    bindsym XF86AudioLowerVolume exec amixer -M set Master 5%- && $refresh_i3status
    bindsym XF86AudioMute exec amixer -M set Master toggle && $refresh_i3status
    bindsym XF86AudioMicMute exec amixer -M set Capture toggle && $refresh_i3status
    bindsym XF86AudioPlay exec playerctl play-pause
    bindsym XF86AudioNext exec playerctl next
    bindsym XF86AudioPrev exec playerctl previous
    bindsym XF86MonBrightnessUp exec xbacklight -inc 10
    bindsym XF86MonBrightnessDown exec xbacklight -dec 10

# Moving around:
#
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right

    bindsym $mod+P focus DP-1
    bindsym $mod+O focus HDMI-A-1
#
# Workspaces:
#
set $ide "IDE"
set $term "Terminal"
set $web "Web"
set $discord "Discord"
set $music "Spotify"
set $steam "Steam"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace $ide
bindsym $mod+2 workspace $term
bindsym $mod+3 workspace $web
bindsym $mod+4 workspace $discord
bindsym $mod+5 workspace $music
bindsym $mod+6 workspace $steam
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace $ide
bindsym $mod+Shift+2 move container to workspace $term
bindsym $mod+Shift+3 move container to workspace $web
bindsym $mod+Shift+4 move container to workspace $discord
bindsym $mod+Shift+5 move container to workspace $music
bindsym $mod+Shift+6 move container to workspace $steam
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

workspace_auto_back_and_forth yes

bindsym $mod+Shift+p move workspace to output DP-1
bindsym $mod+Shift+o move workspace to output HDMI-A-1

assign [class="emacs" instance="Emacs"] $ide
assign [class="Alacritty" instance="Alacritty"] $term
assign [class="firefox" instance="Navigator"] $web
assign [class="discord" instance="discord"] $discord
assign [class="spotify" instance="Spotify"] $music
assign [class="Steam" instance="Steam"] $steam

# Layout stuff:
    bindsym $mod+b splith
    bindsym $mod+v splitv
    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split
    bindsym $mod+f fullscreen
    bindsym $mod+Shift+space floating toggle
    bindsym $mod+space focus mode_toggle
    bindsym $mod+a focus parent
#
# Scratchpad:
#
    # Sway has a "scratchpad", which is a bag of holding for windows.
    # You can send windows there and get them back later.

    # Move the currently focused window to the scratchpad
    bindsym $mod+Shift+minus move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    bindsym $mod+minus scratchpad show
#
# Resizing containers:
#
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

#
# Status Bar:
#
bar {
    swaybar_command waybar
}

bindsym Print exec grim -g "$(slurp)" - | wl-copy && notify-send "Screenshot taken"

for_window [app_id=".*"] border pixel 1
for_window [app_id=".*"] inhibit_idle fullscreen
for_window [class=".*"] inhibit_idle fullscreen
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable

gaps inner 5
gaps outer 5

default_border pixel
default_floating_border pixel

smart_gaps on
smart_gaps inverse_outer
smart_borders on
smart_borders no_gaps

include /etc/sway/config.d/*
