[
  {
    "name": "topbar1",
    "layer": "top",
    "position": "top",
    "height": 30,
    "output": "HDMI-A-1",
    "modules-left": [
      "custom/launcher",
      "custom/sep",
      "memory",
      "cpu",
      "custom/cpu_temp",
      "custom/gpu_percent",
      "custom/gpu_temp",
      "custom/sep"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "custom/sep",
      "network#vpn",
      "network#wifi",
      "network#ethernet",
      "network#disconnected",
      "custom/sep",
      "custom/pacman",
      "custom/sep",
      "custom/poweroff"
    ],
    "sway/window": {
      "format": "{} ",
      "on-click": "swaymsg kill"
    },
    "custom/launcher": {
      "format": " ",
      "on-click": "$HOME/.config/polybar/forest/scripts/launcher.sh &"
    },
    "clock": {
      "interval": 1,
      "format": "<b>{:%a %d-%m-%y %H:%M:%S}</b>",
      "format-alt": "<b>{:%A, %d of %B, %Y %H:%S:%S}</b>",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
      "format": " CPU: {usage}%",
      "tooltip": false,
      "interval": 1
    },
    "memory": {
      "format": " RAM: {used:0.1f}G",
      "tooltip-format": "{used:0.1f}G / {total:0.1f}G used",
      "interval": 1
    },
    "temperature": {
      "critical-threshold": 70,
      "format": "{icon} {temperatureC}°C",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ],
      "interval": 1
    },
    "custom/cpu_temp": {
      "exec": "$HOME/.config/waybar/modules/cpu_temp.sh",
      "format": " {}",
      "interval": 1
    },
    "network#disconnected": {
      "tooltip-format": "No connection!",
      "format-ethernet": "",
      "format-wifi": "",
      "format-linked": "",
      "format-disconnected": "",
      "on-click": "nm-connection-editor"
    },
    "network#ethernet": {
      "interface": "eno*",
      "format-ethernet": " {ifname}: {ipaddr}/{cidr}",
      "format-wifi": "",
      "format-linked": "",
      "format-disconnected": "",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
      "on-click": "nm-connection-editor"
    },
    "network#wifi": {
      "interface": "wlp*",
      "format-ethernet": "",
      "format-wifi": " {essid} ({signalStrength}%)",
      "format-linked": "",
      "format-disconnected": "",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
      "on-click": "nm-connection-editor"
    },
    "network#vpn": {
      "interface": "tun0",
      "format": "",
      "format-disconnected": "",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
      "on-click": "nm-connection-editor"
    },
    "pulseaudio": {
      "scroll-step": 1,
      "format": "{icon} {volume}%{format_source}",
      "format-bluetooth": "{icon} {volume}%{format_source}",
      "format-bluetooth-muted": " {icon}{format_source}",
      "format-muted": " {format_source}",
      "format-source": "  {volume}%",
      "format-source-muted": " ",
      "format-icons": {
        "headphone": "",
        "phone": "",
        "portable": "",
        "car": "",
        "default": [
          "",
          "",
          ""
        ]
      },
      "on-click": "pavucontrol"
    },
    "custom/weather": {
      "return-type": "json",
      "exec": "sh $HOME/.config/waybar/modules/weather.sh",
      "interval": 300,
      "on-click": "firefox https://wttr.in && swaymsg '[app_id=firefox] focus'"
    },
    "custom/poweroff": {
      "tooltip": false,
      "format": " ",
      "on-click": "bash $HOME/.config/waybar/modules/poweroff.sh"
    },
    "custom/mail": {
      "tooltip": false,
      "exec": "sh $HOME/.config/waybar/modules/mail.sh",
      "interval": 120,
      "on-click": "thunderbird && swaymsg '[app_id=thunderbird] focus'"
    },
    "custom/sep": {
      "format": "|",
      "interval": "once",
      "tooltip": false
    },
    "custom/pacman": {
      "format": " Updates: {}",
      "interval": 1,
      "exec": "checkupdates | wc -l",
      "exec-if": "exit 0",
      "on-click": "alacritty -e 'sudo pacman -Syu'; pkill -SIGRTMIN+8 waybar",
      "signal": 8
    },
    "custom/gpu": {
      "exec": "$HOME/.config/waybar/modules/custom-gpu.sh",
      "return-type": "json",
      "format": "{}",
      "interval": 2,
      "tooltip": "{tooltip}",
      "max-length": 19,
      "min-length": 19,
      "on-click": "powerupp"
    },
    "custom/gpu_percent": {
      "exec": "$HOME/.config/waybar/modules/gpu_percent.sh",
      "format": " GPU: {}",
      "interval": 1
    },
    "custom/gpu_temp": {
      "exec": "$HOME/.config/waybar/modules/gpu_temp.sh",
      "format": " {}",
      "interval": 1
    }
  },
