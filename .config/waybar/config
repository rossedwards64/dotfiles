[
    {
        "name": "topbar1",
        "layer": "top",
        "position": "top",
        "height": 32,
        "output": "HDMI-A-1",
        "modules-left": [
            "custom/launcher",
            "custom/sep",
            "memory",
            "cpu",
            "custom/cpu_temp",
            "custom/gpu_percent",
            "custom/gpu_mem",
            "custom/gpu_temp",
            "custom/sep"
        ],
        "modules-center": [
            "clock"
        ],
        "modules-right": [
            "custom/sep",
            "network#vpn",
            "network#wifi",
            "network#ethernet",
            "network#disconnected",
            "custom/sep",
            "custom/pacman",
            "custom/restart_needed",
            "custom/weather",
            "custom/sep",
            "custom/poweroff"
        ],
        "custom/launcher": {
            "format": "´îâ",
            "on-click": "$HOME/.config/rofi/scripts/launcher"
        },
        "clock": {
            "interval": 1,
            "format": "<b>{:%a %d-%m-%y %H:%M:%S}</b>",
            "format-alt": "<b>{:%A, %d of %B, %Y %H:%M:%S}</b>",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
        },
        "cpu": {
            "format": "´őŤ CPU: {usage}% {avg_frequency}GHz",
            "tooltip": false,
            "interval": 1
        },
        "memory": {
            "format": "ţŽ╣ RAM: {used:0.1f}G",
            "tooltip-format": "{used:0.1f}G / {total:0.1f}G used",
            "interval": 1
        },
        "temperature": {
            "critical-threshold": 70,
            "format": "{icon} {temperatureC}┬░C",
            "format-icons": [
                "´őő",
                "´őŐ",
                "´őë",
                "´őł",
                "´őç"
            ],
            "interval": 1
        },
        "custom/cpu_temp": {
            "exec": "$HOME/.config/waybar/modules/cpu_temp",
            "format": "´őç {}",
            "interval": 1
        },
        "network#disconnected": {
            "tooltip-format": "No connection!",
            "format-ethernet": "",
            "format-wifi": "",
            "format-linked": "´üŚ",
            "format-disconnected": "´üŚ",
            "on-click": "nm-connection-editor"
        },
        "network#ethernet": {
            "interface": "eno*",
            "format-ethernet": "´áľ {ifname}: {ipaddr}/{cidr}",
            "format-linked": "",
            "format-disconnected": "{ifname}: N/A",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
            "on-click": "nm-connection-editor"
        },
        "network#wifi": {
            "interface": "wlp*",
            "format-wifi": "´çź {ifname}: {essid} ({signalStrength}%)",
            "format-linked": "",
            "format-disconnected": "{ifname}: N/A",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
            "on-click": "nm-connection-editor"
        },
        "network#vpn": {
            "interface": "tun0",
            "format": "´Çú",
            "format-disconnected": "",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
            "on-click": "nm-connection-editor"
        },
        "pulseaudio": {
            "scroll-step": 1,
            "format": "{icon} {volume}%{format_source}",
            "format-bluetooth": "{icon}´Őö {volume}%{format_source}",
            "format-bluetooth-muted": "´ÇŽ {icon}´Őö{format_source}",
            "format-muted": "´Üę {format_source}",
            "format-source": " ´ä░ {volume}%",
            "format-source-muted": " ´ä▒",
            "format-icons": {
                "headphone": "´Çą",
                "phone": "´éĽ",
                "portable": "´éĽ",
                "car": "´ć╣",
                "default": [
                    "´ÇŽ",
                    "´Çž",
                    "´ÇĘ"
                ]
            },
            "scroll-step": 1,
            "on-click": "alsamixer"
        },
        "custom/weather": {
            "return-type": "json",
            "exec": "sh $HOME/.config/waybar/modules/weather",
            "interval": 300,
            "on-click": "firefox https://wttr.in"
        },
        "custom/poweroff": {
            "tooltip": false,
            "format": "´ÇĹ ",
            "on-click": "bash $HOME/.config/waybar/modules/poweroff"
        },
        "custom/mail": {
            "tooltip": false,
            "exec": "sh $HOME/.config/waybar/modules/mail",
            "interval": 120,
            "on-click": "thunderbird && swaymsg '[app_id=thunderbird] focus'"
        },
        "custom/sep": {
            "format": "|",
            "interval": "once",
            "tooltip": false
        },
        "custom/pacman": {
            "format": "´ćç Updates: {}",
            "interval": 1,
            "exec": "checkupdates | wc -l",
            "exec-if": "exit 0",
            "on-click": "alacritty -e 'sudo pacman -Syu'; pkill -SIGRTMIN+8 waybar",
            "signal": 8
        },
        "custom/restart_needed": {
            "format": "{}",
            "interval": 600,
            "exec": "$HOME/.config/waybar/modules/restart-needed"
        },
        "custom/gpu": {
            "exec": "$HOME/.config/waybar/modules/custom-gpu",
            "return-type": "json",
            "format": "{}",
            "interval": 2,
            "tooltip": "{tooltip}",
            "max-length": 19,
            "min-length": 19,
            "on-click": "powerupp"
        },
        "custom/gpu_percent": {
            "exec": "$HOME/.config/waybar/modules/gpu_percent",
            "format": "´íÜ GPU: {}",
            "interval": 1
        },
        "custom/gpu_temp": {
            "exec": "$HOME/.config/waybar/modules/gpu_temp",
            "format": "´őç {}",
            "interval": 1
        },
        "custom/gpu_mem": {
            "exec": "$HOME/.config/waybar/modules/gpu_mem",
            "format": "{}",
            "interval": 1
        },
    },
    {
        "name": "bottombar1",
        "layer": "top",
        "position": "bottom",
        "height": 32,
        "output": "HDMI-A-1",
        "modules-left": [
            "tray",
            "idle_inhibitor",
            "custom/sep",
            "pulseaudio",
            "custom/spotify",
            "custom/sep"
        ],
        "modules-center": [
            "wlr/taskbar"
        ],
        "modules-right": [
            "custom/sep",
            "disk#root",
            "disk#ssd",
            "disk#hdd",
        ],
        "tray": {
            "icon-size": 24,
            "spacing": 10,
            "show-passive-items": true
        },
        "wlr/taskbar": {
            "format": "{icon} {name}",
            "icon-size": 24,
            "tooltip": false,
            "on-click": "activate",
            "on-click-right": "close"
        },
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "´ü«",
                "deactivated": "´ü░"
            },
            "start-activated": true
        },
        "pulseaudio": {
            "scroll-step": 1,
            "format": "{icon} {volume}%{format_source}",
            "format-bluetooth": "{icon}´Őö {volume}%{format_source}",
            "format-bluetooth-muted": "´ÇŽ {icon}´Őö{format_source}",
            "format-muted": "´Üę {format_source}",
            "format-source": " ´ä░ {volume}%",
            "format-source-muted": " ´ä▒",
            "format-icons": {
                "headphone": "´Çą",
                "phone": "´éĽ",
                "portable": "´éĽ",
                "car": "´ć╣",
                "default": [
                    "´ÇŽ",
                    "´Çž",
                    "´ÇĘ"
                ]
            },
            "scroll-step": 1,
        },
        "custom/spotify": {
            "interval": 1,
            "return-type": "json",
            "exec": "$HOME/.config/waybar/modules/spotify",
            "exec-if": "pgrep spotify",
            "escape": true
        },
        "disk#root": {
            "format": "´éá ROOT: {used}",
            "tooltip-format": "{used} / {total} used",
            "path": "/",
            "interval": 300
        },
        "disk#ssd": {
            "format": "´éá SSD: {used}",
            "tooltip-format": "{used} / {total} used",
            "path": "/home/ross/SSD",
            "interval": 300
        },
        "disk#hdd": {
            "format": "´éá HDD: {used}",
            "tooltip-format": "{used} / {total} used",
            "path": "/home/ross/HDD",
            "interval": 300
        },
        "custom/sep": {
            "format": "|",
            "interval": "once",
            "tooltip": false
        }
    },
