    },
    "custom/gpu_mem": {
      "exec": "$HOME/.config/waybar/modules/gpu_mem.sh",
      "format": " GPU: {}",
      "interval": 1
    },
    "custom/spotify": {
      "interval": 1,
      "return-type": "json",
      "exec": "$HOME/.config/waybar/modules/spotify.sh",
      "exec-if": "pgrep spotify",
      "escape": true
    },
    "custom/sep": {
      "format": "|",
      "interval": "once",
      "tooltip": false
    }
  },
  {
    "name": "bottombar",
    "layer": "top",
    "position": "bottom",
    "height": 30,
    "modules-left": [
      "tray",
      "gamemode",
      "custom/sep",
      "backlight",
      "pulseaudio",
      "idle_inhibitor",
      "custom/sep",
    ],
    "modules-center": [
      "wlr/taskbar"
    ],
    "modules-right": [
      "sway/workspaces",
      "sway/mode",
      "hyprland/window"
    ],
    "tray": {
      "icon-size": 13,
      "spacing": 10
    },
    "wlr/taskbar": {
      "format": "{icon} {name}",
      "icon-size": 13,
      "tooltip": false,
      "on-click": "activate",
      "on-click-right": "close"
    },
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "",
        "deactivated": ""
      }
    },
    "pulseaudio": {
      "format": "{volume}% {icon}",
      "format-bluetooth": "{volume}% {icon}",
      "format-muted": "",
      "format-icons": {
        "headphone": "",
        "hands-free": "",
        "headset": "",
        "phone": "",
        "portable": "",
        "car": "",
        "default": [
          "",
          ""
        ]
      },
      "scroll-step": 1,
      "on-click": "alsamixer"
    },
    "backlight": {
      "device": "intel_backlight",
      "interval": 1,
      "on-scroll-down": "brightlight -pd 1",
      "on-scroll-up": "brightlight -pi 1",
      "format": "{icon} {percent}%",
      "format-icons": [
        "",
        ""
      ],
      "on-click": "wdisplays"
    },
    "gamemode": {
      "format": "{glyph}",
      "format-alt": "{glyph} {count}",
      "glyph": "",
      "hide-not-running": false,
      "use-icon": true,
      "icon-name": "input-gaming-symbolic",
      "icon-spacing": 4,
      "icon-size": 16,
      "tooltip": true,
      "tooltip-format": "Games running: {count}"
    },
    "hyprland/window": {
      "format": "{}"
    },
    "custom/sep": {
    "format": "|",
    "interval": "once",
    "tooltip": false
    }
  }
]
