#!/usr/bin/env bash

temp_input=/sys/class/drm/card0/device/hwmon/[[:print:]]*/temp1_input
pwm1=/sys/class/drm/card0/device/hwmon/[[:print:]]*/pwm1
pwm1_enable=/sys/class/drm/card0/device/hwmon/[[:print:]]*/pwm1_enable

change_speed()
{
    if [[ $1 -lt 0 || $1 -gt 100 ]]; then
        echo "Value given must be between 0 and 100."
    else
        pwm_value=$(echo "scale=2;$1 * 2.55" | bc | awk '{printf "%d", $1}')
        echo "Converted $1 to $pwm_value."
        echo "Now setting fan speed to $1% speed..."
        echo "$pwm_value" | sudo tee -a $pwm1
    fi
}

check_mode()
{
    if [[ "$(cat $pwm1_enable)" == "1" ]]; then
            change_speed "$1"
    else
        echo -n "The GPU fan is currently in automatic mode. Would you like to change it to manual mode? y/n "
        read -r choice

        if [[ $choice == "y" ]]; then
            echo "Setting fan to manual mode..."
            echo 1 | sudo tee -a $pwm1_enable
            change_speed "$1"
        else
            echo "Ending script."
            exit 0
        fi
    fi
}

if [[ $1 == "-h" || $1 == "--help" ]]; then
    echo "Script to edit the graphics card fan speed."
    echo "Enter a PWM value (between 0 and 100) and the speed will be altered."
    exit 0
fi

if [[ $1 == "-r" || $1 == "--read" ]]; then
    percentage=$(cat "$pwm1")
    echo "Current GPU fan speed is: $(echo "scale=2;$percentage / 2.55" | bc | awk '{printf "%d", $percentage}')%"
    exit 0
fi

if [[ $1 == "-d" || $1 == "--daemonize" ]]; then
    fcurve=$(head -n1 ~/.config/gpufan/config)
    tcurve=$(tail -n2 ~/.config/gpufan/config | tr -d '\n')

    readarray -td, farray <<< "$fcurve"; unset "farray[-1]"; declare -p farray;
    readarray -td, tarray <<< "$tcurve"; unset "tarray[-1]"; declare -p tarray;

    while :; do 
        sleep 5 
        temp=$(cat "$temp_input" | bc)
        
        for t in "${!tarray[@]}"
        do 
            echo "$t ${tarray[t]} ${farray[t]}"
            if [[ ${temp::-3} -eq "$t" ]]; then 
                check_mode "${farray[t]}" 
            fi
        done 
    done 

fi

if [[ $1 =~ ^[0-9]+$ ]]; then 
    check_mode "$@"
fi 


